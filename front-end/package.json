{
	"name": "cloud-storage-demo",
	"author": {
		"name": "Anastasiia Balieieva",
		"email": "baleevaanastasiz@gmail.com"
	},
	"type": "module",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev:dashboard": "npm run dev --workspace=apps/dashboard",
		"dev:landing": "npm run dev --workspace=apps/landing",
		"dev": "concurrently \"npm:dev:dashboard\" \"npm:dev:landing\"",
		"clean": "nuxi cleanup && npx nuxi cleanup apps/dashboard && npx nuxi cleanup apps/landing",
		"build:dashboard": "npm run build --workspace=apps/dashboard",
		"build:landing": "npm run build --workspace=apps/landing",
		"build": "npm run build:dashboard && npm run build:landing",
		"start:dashboard": "set PORT=7002 &&  node apps/dashboard/.output/server/index.mjs",
		"start:landing": "set PORT=7001 && node apps/landing/.output/server/index.mjs",
		"start": "concurrently \"npm run start:dashboard\"  \"npm run start:landing\""
	},
	"dependencies": {
		"@nuxt/fonts": "^0.14.0",
		"@nuxt/image": "^2.0.0",
		"@tailwindcss/vite": "^4.3.3",
		"nuxt": "^4.4.8",
		"tailwindcss": "^4.3.3",
		"vue": "^3.5.39",
		"vue-router": "^5.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"concurrently": "^10.0.3",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"prettier-plugin-tailwindcss": "^0.8.1"
	}
}
